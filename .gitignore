# Mac
.DS_Store
.AppleDouble
.LSOverride

# Office temp files
~$*

# Documents (keep locally, don't push to GitHub)
*.docx
*.pdf
*.png
*.jpg
*.jpeg
*.gif

# Exceptions — allow poster HTML files and drawings
!poster-*.html
!index.html
!*.md
!*.js
!*.json
!drawings body parts/
!drawings body parts/*.jpeg
!drawings body parts/*.jpg
!drawings body parts/*.png
